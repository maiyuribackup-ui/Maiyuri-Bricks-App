# React Native (Expo) public env vars — MUST be prefixed EXPO_PUBLIC_ to be
# embedded in the client bundle. Copy to .env and fill in.

# Supabase (same project as the web app — reuse NEXT_PUBLIC_SUPABASE_* values)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Base URL of the deployed Next.js API (your 168 API routes).
# Production custom domain (used by the Capacitor shell too):
EXPO_PUBLIC_API_BASE_URL=https://mb.maiyuri.com
# Or the Vercel URL: https://maiyuri-bricks-app.vercel.app
