    "@supabase/supabase-js": "^2.47.12",
    "@tanstack/query-async-storage-persister": "^5.101.2",
    "@tanstack/react-query": "^5.62.8",
    "@tanstack/react-query-persist-client": "^5.101.2",
    "expo": "~54.0.0",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.0",
    "expo-device": "~8.0.10",
