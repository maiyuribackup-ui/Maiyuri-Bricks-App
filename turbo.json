{
    "$schema": "https://turbo.build/schema.json",
    "globalDependencies": [
        "**/.env.*local"
    ],
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "env": [
                "NODE_ENV",
                "NEXT_PUBLIC_*",
                "SUPABASE_*",
                "TELEGRAM_*",
                "PROJECTS_TELEGRAM_*",
                "CEO_TELEGRAM_CHAT_ID",
                "GOOGLE_*",
                "GEMINI_API_KEY",
                "GA4_*",
                "FCM_*",
                "ANTHROPIC_API_KEY",
                "OPENAI_API_KEY",
                "ODOO_*",
                "RESEND_*",
                "LANGFUSE_*",
                "CRON_SECRET",
                "PROCESSING_WEBHOOK_SECRET",
                "SALESPULSE_TOKEN",
                "CAD_ENGINE_URL",
                "LOG_LEVEL",
                "AUTO_TRIGGER_ANALYSIS",
                "POST_PROCESSING_NUDGE_ENABLED",
                "NUDGE_AI_ENHANCEMENT_ENABLED",
                "ENABLE_FLOOR_PLAN_PERSISTENCE"
            ],
            "outputs": [
                ".next/**",
                "!.next/cache/**",
                "dist/**"
            ]
        },
        "lint": {
            "dependsOn": [
                "^lint"
            ]
        },
        "typecheck": {
            "dependsOn": [
                "^typecheck"
            ]
        },
        "test": {
            "env": [
                "CI"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        }
    }
}